# -----------------------------------------------------------------------------
# @ixtria/outlook-mcp-hardened — environment variables
# -----------------------------------------------------------------------------
# Copy to .env, fill in, keep out of version control.

# Required: Azure Entra ID app registration
MS365_MCP_CLIENT_ID=your-client-id-here
MS365_MCP_TENANT_ID=common
# common   → multi-tenant + personal accounts
# <tenant> → single-tenant (recommended for SME use)

# Optional: confidential client secret (only if your tenant requires it)
# MS365_MCP_CLIENT_SECRET=your-secret-value

# Optional: China 21Vianet cloud
# MS365_MCP_CLOUD_TYPE=china

# -----------------------------------------------------------------------------
# Hardening flags (CLI equivalents: --enable-send / --enable-write)
# -----------------------------------------------------------------------------
# Off by default — this fork is read-only unless you opt in.
# OUTLOOK_MCP_ENABLE_SEND=true
# OUTLOOK_MCP_ENABLE_WRITE=true

# -----------------------------------------------------------------------------
# HTTP mode (off by default; stdio is the primary transport)
# -----------------------------------------------------------------------------
# OUTLOOK_MCP_CORS_ORIGIN=http://localhost:5173
#   When set, overrides the default localhost-only CORS allowlist.
#   '*' is permitted but logs a warning.

# -----------------------------------------------------------------------------
# Debug / logging
# -----------------------------------------------------------------------------
# LOG_LEVEL=info         # error | warn | info | debug
# SILENT=false           # set to 1 to suppress non-audit logs entirely
