# Copy this file to .env and fill in the values.
# Daniel keeps the canonical values in 1Password under "Enabi M365 MCP — App Registration".

# Required. The client ID of Enabi's Azure AD app registration.
# This MCP refuses to start without it. There is no fallback.
MS365_MCP_CLIENT_ID=

# Required. Enabi's Microsoft 365 tenant ID.
MS365_MCP_TENANT_ID=

# Optional. Where to store MSAL token cache if the OS keychain is unavailable.
# Defaults to <repo>/.token-cache.json with 0600 permissions.
# MS365_MCP_TOKEN_CACHE_PATH=~/.config/enabi-m365-mcp/token-cache.json

# Optional. Where to write logs. Defaults to ~/.ms-365-mcp-server/logs/.
# MS365_MCP_LOG_DIR=~/.config/enabi-m365-mcp/logs

# Optional. Where to write the per-tool-call audit log (one JSON line per call).
# Defaults to ~/.config/enabi-m365-mcp/audit/audit-YYYY-MM-DD.log
# MS365_MCP_AUDIT_LOG_DIR=~/.config/enabi-m365-mcp/audit
# Set MS365_MCP_AUDIT_DISABLED=1 to turn off audit logging entirely (not recommended).

# Do NOT set MS365_MCP_CLIENT_SECRET unless you are running in HTTP+OBO mode.
# For employee laptop installs, leave it unset.
