{
  "name": "@ixtria/outlook-mcp-hardened",
  "version": "0.1.0",
  "description": "Security-hardened MCP server for Microsoft Outlook (Mail + Calendar). Fork of @softeria/ms-365-mcp-server with egress allowlist, audit trail, anti-prompt-injection, and read-first defaults.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "outlook-mcp-hardened": "dist/index.js"
  },
  "scripts": {
    "generate": "node bin/generate-graph-client.mjs",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx --watch src/index.ts --http 127.0.0.1:3000 -v",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "verify": "npm run generate && npm run lint && npm run typecheck && npm run build && npm run test",
    "inspector": "npx @modelcontextprotocol/inspector tsx src/index.ts"
  },
  "keywords": [
    "microsoft",
    "outlook",
    "mail",
    "calendar",
    "mcp",
    "model-context-protocol",
    "hardened",
    "security",
    "ixtria"
  ],
  "author": "Ixtria SA <hello@ixtria.ch>",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@azure/msal-node": "^3.8.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^11.1.0",
    "dotenv": "^17.0.1",
    "express": "^5.2.1",
    "open": "^11.0.0",
    "winston": "^3.17.0",
    "zod": "^3.24.2"
  },
  "optionalDependencies": {
    "@azure/identity": "^4.5.0",
    "@azure/keyvault-secrets": "^4.9.0",
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@redocly/cli": "^2.11.1",
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.15",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.31.0",
    "globals": "^16.3.0",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Ixtria/outlook-mcp-hardened.git"
  },
  "homepage": "https://github.com/Ixtria/outlook-mcp-hardened",
  "bugs": {
    "url": "https://github.com/Ixtria/outlook-mcp-hardened/issues"
  }
}
