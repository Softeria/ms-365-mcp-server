# === Required: Azure Entra ID (Confidential Client) ===
ENTRA_TENANT_ID=your-tenant-id
ENTRA_CLIENT_ID=your-client-id
ENTRA_CLIENT_SECRET=your-client-secret

# === Optional: URLs ===
# Public URL of this proxy (used for OAuth metadata & redirect URIs)
PUBLIC_URL=http://localhost:8080

# Backend ms-365-mcp-server URL
MS365_MCP_URL=http://localhost:3000

# Proxy listen port
PORT=8080

# === Optional: JWT signing secret ===
# If not set, a random secret is generated at startup (tokens invalidated on restart)
# JWT_SECRET=your-random-secret-here

# === Optional: Graph API scopes ===
# Space-separated list of Microsoft Graph scopes to request
# If not set, a comprehensive default set is used
# GRAPH_SCOPES=openid profile email offline_access User.Read Mail.Read Mail.ReadWrite Mail.Send Calendars.Read Calendars.ReadWrite Files.Read Files.ReadWrite
